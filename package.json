{
  "name": "react-file-viewer",
  "version": "1.4.0",
  "description": "Extendable file viewer for web",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mobilizeio/react-file-viewer.git"
  },
  "scripts": {
    "dev": "webpack -d --watch",
    "build": "webpack --progress",
    "start": "node ./scripts/start.js",
    "lint": "node_modules/.bin/eslint ./src/**/*.jsx",
    "test": "node_modules/.bin/jest --watch",
    "jest": "node_modules/.bin/jest",
    "tag-and-publish": "node ./scripts/publish.js"
  },
  "author": "PlanGrid <opensource@plangrid.com>",
  "contributors": [
    {
      "name": "Alexei Schiopu",
      "email": "alexxschiopu@gmail.com",
      "url": "http://schiopu.me"
    },
    {
      "name": "Aaron Norby",
      "email": "aaron.norby@gmail.com"
    },
    {
      "name": "Viktoriya Savkina",
      "email": "viktoriya.savkina@gmail.com"
    }
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/plangrid/react-file-viewer/issues"
  },
  "homepage": "https://github.com/plangrid/react-file-viewer#readme",
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.28.5",
    "@babel/runtime": "^7.29.2",
    "@wojtekmaj/enzyme-adapter-react-17": "^0.8.0",
    "autoprefixer": "^10.4.27",
    "babel-jest": "^30.3.0",
    "babel-loader": "^10.1.1",
    "chalk": "^4.1.2",
    "css-loader": "^7.1.4",
    "enzyme": "^3.11.0",
    "eslint": "^8.57.1",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-import-resolver-webpack": "^0.13.10",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-webpack-plugin": "^4.0.1",
    "file-loader": "^6.2.0",
    "html-webpack-plugin": "^5.6.6",
    "inquirer": "^8.2.7",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "postcss-loader": "^8.2.1",
    "process": "^0.11.10",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "react-test-renderer": "^17.0.2",
    "readable-stream": "^4.7.0",
    "sass": "^1.98.0",
    "sass-loader": "^16.0.7",
    "stream-browserify": "^3.0.0",
    "style-loader": "^4.0.0",
    "url-loader": "^4.1.1",
    "util": "^0.12.5",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.3"
  },
  "dependencies": {
    "@e965/xlsx": "^0.20.3",
    "comma-separated-values": "^3.6.4",
    "mammoth": "^1.12.0",
    "prop-types": "^15.8.1",
    "react-data-grid": "7.0.0-canary.49",
    "react-pdf": "^10.4.1",
    "react-visibility-sensor": "^5.1.1",
    "three": "0.183.2"
  },
  "overrides": {
    "node-sass": "npm:sass@^1.98.0"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "jest": {
    "testPathIgnorePatterns": [
      "<rootDir>[/\\\\](build|node_modules|scripts|example_files)[/\\\\]"
    ],
    "testEnvironment": "jsdom",
    "transform": {
      "^.+\\.(js|jsx)$": "babel-jest",
      "^.+\\.(css|scss)$": "<rootDir>/config/jest/cssTransform.js",
      "^(?!.*\\.(js|jsx|css|json)$)": "<rootDir>/config/jest/fileTransform.js"
    },
    "transformIgnorePatterns": [
      "[/\\\\]node_modules[/\\\\].+\\.(js|jsx)$"
    ],
    "moduleNameMapper": {
      "react-pdf": "<rootDir>/tests/__mocks__/react-pdf.js"
    },
    "moduleDirectories": [
      "src",
      "node_modules"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/tests/setupTests.js"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
